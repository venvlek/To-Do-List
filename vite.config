import { defineConfig } from "vite";
import react from "@vitejs/plugin-react";

// https://vitejs.dev/config/
export default defineConfig({
  plugins: [react()],

  // ── PWA Service Worker ──────────────────────────────────────────────────────
  // We use a manual service worker (public/sw.js) rather than vite-plugin-pwa
  // so you don't need to install an extra dependency.
  // The SW is registered in src/main.jsx.

  build: {
    // Generate source maps for easier debugging
    sourcemap: false,
    // Optimise chunk sizes
    rollupOptions: {
      output: {
        manualChunks: {
          // Split Firebase into its own chunk (it's large)
          firebase: ["firebase/app", "firebase/auth", "firebase/firestore"],
          // Split React into its own chunk
          react:    ["react", "react-dom"],
        },
      },
    },
  },

  server: {
    // Allow PWA testing on your local network (so you can test on mobile)
    host: true,
    port: 5173,
  },
});
